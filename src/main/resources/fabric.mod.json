    ]
  },
  "mixins": [
    "booklet.mixins.json"
  ],

  "depends": {
    "fabricloader": ">=0.16.0",
    "fabric-api": "*",
    "minecraft": ">=26.1-",
    "polymer-core": ">=0.10.0-",
    "polymer-resource-pack": ">=0.10.0-",
    "java": ">=25"
