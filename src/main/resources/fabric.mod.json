{
  "schemaVersion": 1,
  "id": "booklet",
  "version": "${version}",
  "name": "Booklet",
  "description": "A server-side, data driven, in-game guidebook implementation!",
  "authors": [
    "Patbox"
  ],
  "contact": {
    "homepage": "https://pb4.eu",
    "sources": "https://github.com/Patbox/booklet"
  },
  "license": "LGPLv3",
  "icon": "assets/booklet/textures/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "eu.pb4.booklet.impl.BookletInit::init"
    ],
    "fabric-datagen": [
